# Copy to .env and fill in. NEVER commit real keys.

# Commercial PDF engine (Apryse/Foxit). Absent = open-source PDF.js viewer only.
VITE_APRYSE_LICENSE_KEY=

# Base URL of the conversion/OCR backend (services/converter).
VITE_CONVERTER_URL=http://localhost:8787

# Converter service port (services/converter).
PORT=8787

# Anthropic API key for the built-in AI assistant.
# Desktop: read by the Tauri `ai_message` command (stays native, never in the webview).
# Web: read by the converter service's /ai proxy. Never expose it to the browser.
ANTHROPIC_API_KEY=

# Optional: override the AI proxy URL used by the web build (defaults to
# $VITE_CONVERTER_URL/ai). Not used by the desktop build.
VITE_AI_PROXY_URL=
